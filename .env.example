# JWT signing secret — change this to a long random string in production
SECRET_KEY=your-secret-key-change-in-production

# Path to SQLite database file (relative to backend/ directory)
# Recreated from scratch every time the app starts
DATABASE_PATH=app.db

# OpenRouter API key for AI features (future use)
OPENROUTER_API_KEY=your_openrouter_api_key_here
